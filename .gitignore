# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/

# ── Environment files — never commit secrets ─────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# ── Build artefacts ───────────────────────────────────────────────────────────
dist/
build/

# ── Drizzle generated (keep migrations, exclude snapshots) ───────────────────
drizzle/meta/

# ── Playwright ────────────────────────────────────────────────────────────────
/playwright-report/
/test-results/
e2e/.auth/           # session cookies — never commit; regenerated by auth.setup.ts

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.log
*.tsbuildinfo
.vercel
.turbo
