# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/

# ── Environment — NEVER commit files with secrets ────────────────────────────
.env.local              # your real dev secrets — never commit
.env.*.local            # environment-specific local overrides
.env.production         # production secrets — manage via Vercel dashboard
# .env.development is intentionally NOT ignored — it has no secrets

# ── Build artefacts ───────────────────────────────────────────────────────────
dist/
build/

# ── Drizzle ───────────────────────────────────────────────────────────────────
drizzle/meta/

# ── Playwright ────────────────────────────────────────────────────────────────
/playwright-report/
/test-results/
e2e/.auth/

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.log
*.tsbuildinfo
.vercel
.turbo
.env.local
