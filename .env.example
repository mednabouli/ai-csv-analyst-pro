# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Lines marked REQUIRED must be set before `pnpm dev` works.
# Lines marked OPTIONAL enable additional features.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to https://yourdomain.com in prod

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-32-char-secret-here

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# Neon (free tier): https://neon.tech — create a project, copy the connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── AI Provider (REQUIRED — at least one) ────────────────────────────────────
# Google AI Studio (free): https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# These are optional — add when you want to use those models:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434/api  (for local Gemma models)

# ── Email (OPTIONAL — dev logs to console without this) ──────────────────────
# Resend (free tier): https://resend.com — create account, verify domain
# RESEND_API_KEY=re_...
# EMAIL_DOMAIN=yourdomain.com

# ── Redis / Rate Limiting (OPTIONAL — rate limiting skipped without this) ────
# Upstash (free tier): https://upstash.com — create Redis database
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Stripe / Billing (OPTIONAL — billing UI shows but checkout disabled) ─────
# Stripe: https://dashboard.stripe.com — get test keys first
# After adding key, run: pnpm stripe:setup  to create products
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...

# ── OAuth Social Login (OPTIONAL — buttons hidden without these) ──────────────
# See docs/oauth-setup.md for step-by-step instructions
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# GITHUB_CLIENT_ID=Iv1...
# GITHUB_CLIENT_SECRET=xxx

# ── Observability (OPTIONAL) ─────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# ── Cron (OPTIONAL) ──────────────────────────────────────────────────────────
# CRON_SECRET=any-random-string
